# ============================================================
# .gitignore — ArchAware-PDDL-Configurator
# Protects secrets, thesis PDFs, and Eli's legacy code
# ============================================================

# ──────────────────────────────────────────────────────────────
# 1. Secrets & Environment (ONLY actual API key files)
# ──────────────────────────────────────────────────────────────
.env
config/.env

# ──────────────────────────────────────────────────────────────
# 2. Python Artifacts
# ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# ──────────────────────────────────────────────────────────────
# 3. PDFs — Thesis documents (not for public commits)
# ──────────────────────────────────────────────────────────────
PDFs/
*.pdf
LLM Modulo Feedback Loop Implementation Helper/
VIP Documents/

# ──────────────────────────────────────────────────────────────
# 4. Markdowns — Converted thesis PDFs (not for public commits)
# ──────────────────────────────────────────────────────────────
Markdowns/

# ──────────────────────────────────────────────────────────────
# 5. Walkthroughs — Personal reference notes per commit
# ──────────────────────────────────────────────────────────────
Walkthroughs/

# ──────────────────────────────────────────────────────────────
# 5. Daniel Eli's Legacy Source Code (reference only)
# ──────────────────────────────────────────────────────────────
Elis Code/

# ──────────────────────────────────────────────────────────────
# 6. Raw Domain Staging Folder (already placed in benchmarks/)
# ──────────────────────────────────────────────────────────────
DOMAINS TO BE PLACED/

# ──────────────────────────────────────────────────────────────
# 6. Planner Docker Build Artifacts (heavy cloned repos)
# ──────────────────────────────────────────────────────────────
planners/*/downward/
planners/*/builds/
planners/*/*.tar.gz

# ──────────────────────────────────────────────────────────────
# 7. IDE & OS Artifacts
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────────────────────
# 8. Jupyter Notebook Checkpoints
# ──────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ──────────────────────────────────────────────────────────────
# 9. Utility / Temporary Scripts
# ──────────────────────────────────────────────────────────────
convert_pdfs.py
generate_html.py
text.txt

# Proprietary/Large Binaries
planners/decstar/cplex_*.bin

