(define (domain barman)
  (:requirements :strips :typing)
  (:types hand level beverage dispenser container - object
          ingredient cocktail - beverage
          shot shaker - container)
  (:predicates  (handempty ?h - hand)
                (ontable ?c - container)
                (empty ?c - container)
                (clean ?c - container)
                (unshaked ?s - shaker)
                (shaked ?s - shaker)
                (holding ?h - hand ?c - container)
                (contains ?c - container ?b - beverage)
                (used ?c - container ?b - beverage)
                (shaker-empty-level ?s - shaker ?l - level)
                (shaker-level ?s - shaker ?l - level)
                (dispenses ?d - dispenser ?i - ingredient)
                (next ?l1 ?l2 - level)
                (cocktail-part1 ?c - cocktail ?i - ingredient)
                (cocktail-part2 ?c - cocktail ?i - ingredient))

  (:action clean-shaker
           :parameters (?h1 ?h2 - hand ?s - shaker)
           :precondition (and (empty ?s)
                              (holding ?h1 ?s)
                              (handempty ?h2))
           :effect (and (clean ?s)))

  (:action empty-shot
           :parameters (?h - hand ?p - shot ?b - beverage)
           :precondition (and (contains ?p ?b)
                              (holding ?h ?p))
           :effect (and (empty ?p)
                        (not (contains ?p ?b))))

  (:action empty-shaker
           :parameters (?h - hand ?s - shaker ?b - cocktail ?l ?l1 - level)
           :precondition (and (shaked ?s)
                              (contains ?s ?b)
                              (holding ?h ?s)
                              (shaker-level ?s ?l)
                              (shaker-empty-level ?s ?l1))
           :effect (and (empty ?s)
                        (not (shaked ?s))
                        (not (contains ?s ?b))
                        (not (shaker-level ?s ?l))
                        (shaker-level ?s ?l1)))

  (:action clean-shot
           :parameters (?s - shot ?b - beverage ?h1 ?h2 - hand)
           :precondition (and (empty ?s)
                              (used ?s ?b)
                              (holding ?h1 ?s)
                              (handempty ?h2))
           :effect (and (clean ?s)
                        (not (used ?s ?b))))

  (:action grasp
           :parameters (?h - hand ?c - container)
           :precondition (and (ontable ?c)
                              (handempty ?h))
           :effect (and (not (ontable ?c))
                        (holding ?h ?c)
                        (not (handempty ?h))))

  (:action leave
           :parameters (?h - hand ?c - container)
           :precondition (and (holding ?h ?c))
           :effect (and (ontable ?c)
                        (not (holding ?h ?c))
                        (handempty ?h)))

  (:action fill-shot
           :parameters (?s - shot ?i - ingredient ?h1 ?h2 - hand ?d - dispenser)
           :precondition (and (empty ?s)
                              (clean ?s)
                              (holding ?h1 ?s)
                              (handempty ?h2)
                              (dispenses ?d ?i))
           :effect (and (not (empty ?s))
                        (not (clean ?s))
                        (contains ?s ?i)
                        (used ?s ?i)))

  (:action refill-shot
           :parameters (?s - shot ?i - ingredient ?h1 ?h2 - hand ?d - dispenser)
           :precondition (and (empty ?s)
                              (used ?s ?i)
                              (holding ?h1 ?s)
                              (handempty ?h2)
                              (dispenses ?d ?i))
           :effect (and (not (empty ?s))
                        (contains ?s ?i)))

  (:action shake
           :parameters (?b - cocktail ?d1 ?d2 - ingredient ?s - shaker ?h1 ?h2 - hand)
           :precondition (and (unshaked ?s)
                              (contains ?s ?d1)
                              (contains ?s ?d2)
                              (holding ?h1 ?s)
                              (handempty ?h2)
                              (cocktail-part1 ?b ?d1)
                              (cocktail-part2 ?b ?d2))
           :effect (and (shaked ?s)
                        (not (unshaked ?s))
                        (not (contains ?s ?d1))
                        (not (contains ?s ?d2))
                        (contains ?s ?b)))

  (:action pour-shot-to-clean-shaker
           :parameters (?s - shot ?i - ingredient ?d - shaker ?h1 - hand ?l ?l1 - level)
           :precondition (and (contains ?s ?i)
                              (empty ?d)
                              (clean ?d)
                              (holding ?h1 ?s)
                              (shaker-level ?d ?l)
                              (next ?l ?l1))
           :effect (and (empty ?s)
                        (not (contains ?s ?i))
                        (not (empty ?d))
                        (not (clean ?d))
                        (unshaked ?d)
                        (contains ?d ?i)
                        (not (shaker-level ?d ?l))
                        (shaker-level ?d ?l1)))

  (:action pour-shot-to-used-shaker
           :parameters (?s - shot ?i - ingredient ?d - shaker ?h1 - hand ?l ?l1 - level)
           :precondition (and (contains ?s ?i)
                              (unshaked ?d)
                              (holding ?h1 ?s)
                              (shaker-level ?d ?l)
                              (next ?l ?l1))
           :effect (and (empty ?s)
                        (not (contains ?s ?i))
                        (contains ?d ?i)
                        (not (shaker-level ?d ?l))
                        (shaker-level ?d ?l1)))

  (:action pour-shaker-to-shot
           :parameters (?b - beverage ?d - shot ?h - hand ?s - shaker ?l ?l1 - level)
           :precondition (and (shaked ?s)
                              (contains ?s ?b)
                              (empty ?d)
                              (clean ?d)
                              (holding ?h ?s)
                              (shaker-level ?s ?l)
                              (next ?l1 ?l))
           :effect (and (not (shaker-level ?s ?l))
                        (shaker-level ?s ?l1)
                        (not (empty ?d))
                        (not (clean ?d))
                        (contains ?d ?b)))
)