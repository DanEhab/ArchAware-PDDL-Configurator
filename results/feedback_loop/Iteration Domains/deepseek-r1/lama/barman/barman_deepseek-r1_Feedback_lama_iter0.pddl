(define (domain barman)
  (:requirements :strips :typing)
  (:types hand level beverage dispenser container - object
  	  ingredient cocktail - beverage
          shot shaker - container)
  (:predicates (contains ?c - container ?b - beverage)
               (shaked ?s - shaker)
               (clean ?c - container)
               (empty ?c - container)
               (handempty ?h - hand)
               (holding ?h - hand ?c - container)
               (ontable ?c - container)
               (unshaked ?s - shaker)
               (used ?c - container ?b - beverage)
               (shaker-level ?s - shaker ?l - level)
               (shaker-empty-level ?s - shaker ?l - level)
               (next ?l1 ?l2 - level)
               (dispenses ?d - dispenser ?i - ingredient)
               (cocktail-part1 ?c - cocktail ?i - ingredient)
               (cocktail-part2 ?c - cocktail ?i - ingredient))
  (:action leave
             :parameters (?h - hand ?c - container)
             :precondition (holding ?h ?c)
             :effect (and (handempty ?h)
                          (ontable ?c)
                          (not (holding ?h ?c))))
  (:action grasp
             :parameters (?h - hand ?c - container)
             :precondition (and (ontable ?c) (handempty ?h))
             :effect (and (holding ?h ?c)
                          (not (ontable ?c))
                          (not (handempty ?h))))
  (:action empty-shot
           :parameters (?h - hand ?p - shot ?b - beverage)
           :precondition (and (contains ?p ?b)
                              (holding ?h ?p))
           :effect (and (empty ?p)
                        (not (contains ?p ?b))))
  (:action clean-shaker
  	   :parameters (?h1 ?h2 - hand ?s - shaker)
           :precondition (and (empty ?s)
                              (holding ?h1 ?s)
                              (handempty ?h2))
           :effect (and (clean ?s)))
  (:action clean-shot
  	   :parameters (?s - shot ?b - beverage ?h1 ?h2 - hand)
           :precondition (and (used ?s ?b)
                              (empty ?s)
                              (holding ?h1 ?s)
                              (handempty ?h2))
           :effect (and (clean ?s)
                        (not (used ?s ?b))))
  (:action pour-shot-to-used-shaker
           :parameters (?s - shot ?i - ingredient ?d - shaker ?h1 - hand ?l ?l1 - level)
           :precondition (and (next ?l ?l1)
                              (contains ?s ?i)
                              (holding ?h1 ?s)
                              (shaker-level ?d ?l)
                              (unshaked ?d))
           :effect (and (contains ?d ?i)
                        (shaker-level ?d ?l1)
                        (empty ?s)
                        (not (contains ?s ?i))
                        (not (shaker-level ?d ?l))))
  (:action fill-shot
           :parameters (?s - shot ?i - ingredient ?h1 ?h2 - hand ?d - dispenser)
           :precondition (and (dispenses ?d ?i)
                              (clean ?s)
                              (empty ?s)
                              (holding ?h1 ?s)
                              (handempty ?h2))
           :effect (and (contains ?s ?i)
                        (used ?s ?i)
                        (not (empty ?s))
                        (not (clean ?s))))
  (:action refill-shot
           :parameters (?s - shot ?i - ingredient ?h1 ?h2 - hand ?d - dispenser)
           :precondition (and (dispenses ?d ?i)
                              (used ?s ?i)
                              (empty ?s)
                              (holding ?h1 ?s)
                              (handempty ?h2))
           :effect (and (contains ?s ?i)
                        (not (empty ?s))))
  (:action empty-shaker
           :parameters (?h - hand ?s - shaker ?b - cocktail ?l ?l1 - level)
           :precondition (and (shaker-empty-level ?s ?l1)
                              (contains ?s ?b)
                              (shaked ?s)
                              (shaker-level ?s ?l)
                              (holding ?h ?s))
           :effect (and (empty ?s)
                        (shaker-level ?s ?l1)
                        (not (shaked ?s))
                        (not (shaker-level ?s ?l))
                        (not (contains ?s ?b))))
  (:action pour-shot-to-clean-shaker
           :parameters (?s - shot ?i - ingredient ?d - shaker ?h1 - hand ?l ?l1 - level)
           :precondition (and (next ?l ?l1)
                              (clean ?d)
                              (empty ?d)
                              (shaker-level ?d ?l)
                              (contains ?s ?i)
                              (holding ?h1 ?s))
           :effect (and (contains ?d ?i)
                        (unshaked ?d)
                        (shaker-level ?d ?l1)
                        (empty ?s)
                        (not (contains ?s ?i))
                        (not (empty ?d))
                        (not (clean ?d))
                        (not (shaker-level ?d ?l))))
  (:action shake
  	   :parameters (?b - cocktail ?d1 ?d2 - ingredient ?s - shaker ?h1 ?h2 - hand)
           :precondition (and (cocktail-part1 ?b ?d1)
                              (cocktail-part2 ?b ?d2)
                              (contains ?s ?d1)
                              (contains ?s ?d2)
                              (unshaked ?s)
                              (handempty ?h2)
                              (holding ?h1 ?s))
           :effect (and (contains ?s ?b)
                        (shaked ?s)
                        (not (unshaked ?s))
                        (not (contains ?s ?d1))
                        (not (contains ?s ?d2))))
  (:action pour-shaker-to-shot
           :parameters (?b - beverage ?d - shot ?h - hand ?s - shaker ?l ?l1 - level)
           :precondition (and (next ?l1 ?l)
                              (contains ?s ?b)
                              (shaked ?s)
                              (shaker-level ?s ?l)
                              (clean ?d)
                              (empty ?d)
                              (holding ?h ?s))
           :effect (and (contains ?d ?b)
                        (shaker-level ?s ?l1)
                        (not (clean ?d))
                        (not (empty ?d))
                        (not (shaker-level ?s ?l))))
)