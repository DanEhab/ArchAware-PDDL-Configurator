(define (domain barman)
  (:requirements :strips :typing)
  (:types hand level beverage dispenser container - object
          ingredient cocktail - beverage
          shot shaker - container)
  (:predicates (ontable ?c - container)
               (empty ?c - container)
               (clean ?c - container)
               (unshaked ?s - shaker)
               (shaked ?s - shaker)
               (handempty ?h - hand)
               (shaker-empty-level ?s - shaker ?l - level)
               (shaker-level ?s - shaker ?l - level)
               (dispenses ?d - dispenser ?i - ingredient)
               (cocktail-part1 ?c - cocktail ?i - ingredient)
               (cocktail-part2 ?c - cocktail ?i - ingredient)
               (holding ?h - hand ?c - container)
               (contains ?c - container ?b - beverage)
               (used ?c - container ?b - beverage)
               (next ?l1 ?l2 - level))

  (:action empty-shot
           :parameters (?h - hand ?p - shot ?b - beverage)
           :precondition (and (holding ?h ?p)
                              (contains ?p ?b))
           :effect (and (not (contains ?p ?b))
                        (empty ?p)))

  (:action clean-shot
           :parameters (?s - shot ?b - beverage ?h1 ?h2 - hand)
           :precondition (and (empty ?s)
                              (used ?s ?b)
                              (holding ?h1 ?s)
                              (handempty ?h2))
           :effect (and (not (used ?s ?b))
                        (clean ?s)))

  (:action clean-shaker
           :parameters (?h1 ?h2 - hand ?s - shaker)
           :precondition (and (empty ?s)
                              (holding ?h1 ?s)
                              (handempty ?h2))
           :effect (and (clean ?s)))

  (:action grasp
           :parameters (?h - hand ?c - container)
           :precondition (and (ontable ?c)
                              (handempty ?h))
           :effect (and (not (ontable ?c))
                        (not (handempty ?h))
                        (holding ?h ?c)))

  (:action leave
           :parameters (?h - hand ?c - container)
           :precondition (holding ?h ?c)
           :effect (and (not (holding ?h ?c))
                        (ontable ?c)
                        (handempty ?h)))

  (:action fill-shot
           :parameters (?s - shot ?i - ingredient ?h1 ?h2 - hand ?d - dispenser)
           :precondition (and (empty ?s)
                              (clean ?s)
                              (holding ?h1 ?s)
                              (dispenses ?d ?i)
                              (handempty ?h2))
           :effect (and (not (empty ?s))
                        (not (clean ?s))
                        (contains ?s ?i)
                        (used ?s ?i)))

  (:action refill-shot
           :parameters (?s - shot ?i - ingredient ?h1 ?h2 - hand ?d - dispenser)
           :precondition (and (empty ?s)
                              (used ?s ?i)
                              (holding ?h1 ?s)
                              (dispenses ?d ?i)
                              (handempty ?h2))
           :effect (and (not (empty ?s))
                        (contains ?s ?i)))

  (:action empty-shaker
           :parameters (?h - hand ?s - shaker ?b - cocktail ?l ?l1 - level)
           :precondition (and (contains ?s ?b)
                              (shaked ?s)
                              (shaker-level ?s ?l)
                              (shaker-empty-level ?s ?l1)
                              (holding ?h ?s))
           :effect (and (not (shaked ?s))
                        (not (shaker-level ?s ?l))
                        (not (contains ?s ?b))
                        (shaker-level ?s ?l1)
                        (empty ?s)))

  (:action shake
           :parameters (?b - cocktail ?d1 ?d2 - ingredient ?s - shaker ?h1 ?h2 - hand)
           :precondition (and (contains ?s ?d1)
                              (contains ?s ?d2)
                              (unshaked ?s)
                              (holding ?h1 ?s)
                              (cocktail-part1 ?b ?d1)
                              (cocktail-part2 ?b ?d2)
                              (handempty ?h2))
           :effect (and (not (unshaked ?s))
                        (not (contains ?s ?d1))
                        (not (contains ?s ?d2))
                        (shaked ?s)
                        (contains ?s ?b)))

  (:action pour-shot-to-clean-shaker
           :parameters (?s - shot ?i - ingredient ?d - shaker ?h1 - hand ?l ?l1 - level)
           :precondition (and (contains ?s ?i)
                              (holding ?h1 ?s)
                              (empty ?d)
                              (clean ?d)
                              (shaker-level ?d ?l)
                              (next ?l ?l1))
           :effect (and (not (contains ?s ?i))
                        (empty ?s)
                        (contains ?d ?i)
                        (not (empty ?d))
                        (not (clean ?d))
                        (unshaked ?d)
                        (not (shaker-level ?d ?l))
                        (shaker-level ?d ?l1)))

  (:action pour-shot-to-used-shaker
           :parameters (?s - shot ?i - ingredient ?d - shaker ?h1 - hand ?l ?l1 - level)
           :precondition (and (contains ?s ?i)
                              (holding ?h1 ?s)
                              (unshaked ?d)
                              (shaker-level ?d ?l)
                              (next ?l ?l1))
           :effect (and (not (contains ?s ?i))
                        (empty ?s)
                        (contains ?d ?i)
                        (not (shaker-level ?d ?l))
                        (shaker-level ?d ?l1)))

  (:action pour-shaker-to-shot
           :parameters (?b - beverage ?d - shot ?h - hand ?s - shaker ?l ?l1 - level)
           :precondition (and (empty ?d)
                              (clean ?d)
                              (contains ?s ?b)
                              (shaked ?s)
                              (shaker-level ?s ?l)
                              (holding ?h ?s)
                              (next ?l1 ?l))
           :effect (and (not (clean ?d))
                        (not (empty ?d))
                        (contains ?d ?b)
                        (shaker-level ?s ?l1)
                        (not (shaker-level ?s ?l))))
)