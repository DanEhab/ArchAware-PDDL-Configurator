(define (domain barman)
  (:requirements :strips :typing)
  (:types hand level beverage dispenser container - object
  	  ingredient cocktail - beverage
          shot shaker - container)
  (:predicates  (ontable ?c - container)
                (holding ?h - hand ?c - container)
		(handempty ?h - hand)
		(empty ?c - container)
                (contains ?c - container ?b - beverage)
		(clean ?c - container)
                (used ?c - container ?b - beverage)
                (dispenses ?d - dispenser ?i - ingredient)
		(shaker-empty-level ?s - shaker ?l - level)
		(shaker-level ?s - shaker ?l - level)
		(next ?l1 ?l2 - level)
		(unshaked ?s - shaker)
		(shaked ?s - shaker)
                (cocktail-part1 ?c - cocktail ?i - ingredient)
                (cocktail-part2 ?c - cocktail ?i - ingredient))

  (:action grasp
             :parameters (?h - hand ?c - container)
             :precondition (and (handempty ?h) (ontable ?c))
             :effect (and (holding ?h ?c)
	     	     	  (not (ontable ?c))
			  (not (handempty ?h))))

  (:action leave
             :parameters (?h - hand ?c - container)
             :precondition (holding ?h ?c)
             :effect (and (handempty ?h)
			  (ontable ?c)
	     	     	  (not (holding ?h ?c))))

  (:action fill-shot
           :parameters (?s - shot ?i - ingredient ?h1 ?h2 - hand ?d - dispenser)
           :precondition (and (holding ?h1 ?s)
			      (clean ?s)
                              (empty ?s)
                              (handempty ?h2)
	   		      (dispenses ?d ?i))
           :effect (and (contains ?s ?i)
			(used ?s ?i)
	   	   	(not (clean ?s))
			(not (empty ?s))))

  (:action refill-shot
           :parameters (?s - shot ?i - ingredient ?h1 ?h2 - hand ?d - dispenser)
           :precondition (and (holding ?h1 ?s)
                              (empty ?s)
			      (used ?s ?i)
                              (handempty ?h2)
	   		      (dispenses ?d ?i))
           :effect (and (contains ?s ?i)
                        (not (empty ?s))))

  (:action empty-shot
           :parameters (?h - hand ?p - shot ?b - beverage)
           :precondition (and (holding ?h ?p)
                              (contains ?p ?b))
           :effect (and (empty ?p)
	   	   	(not (contains ?p ?b))))

  (:action clean-shot
  	   :parameters (?s - shot ?b - beverage ?h1 ?h2 - hand)
           :precondition (and (holding ?h1 ?s)
			      (empty ?s)
                              (used ?s ?b)
                              (handempty ?h2))
           :effect (and (clean ?s)
	   	   	(not (used ?s ?b))))

  (:action pour-shot-to-clean-shaker
           :parameters (?s - shot ?i - ingredient ?d - shaker ?h1 - hand ?l ?l1 - level)
           :precondition (and (holding ?h1 ?s)
			      (contains ?s ?i)
	   		      (clean ?d)
                              (empty ?d)
                              (shaker-level ?d ?l)
                              (next ?l ?l1))
           :effect (and (contains ?d ?i)
			(unshaked ?d)
			(shaker-level ?d ?l1)
			(empty ?s)
			(not (contains ?s ?i))
                        (not (empty ?d))
			(not (clean ?d))
			(not (shaker-level ?d ?l))))

  (:action pour-shot-to-used-shaker
           :parameters (?s - shot ?i - ingredient ?d - shaker ?h1 - hand ?l ?l1 - level)
           :precondition (and (holding ?h1 ?s)
			      (contains ?s ?i)
                              (unshaked ?d)
                              (shaker-level ?d ?l)
                              (next ?l ?l1))
           :effect (and (contains ?d ?i)
			(shaker-level ?d ?l1)
	   	   	(empty ?s)
			(not (contains ?s ?i))
  			(not (shaker-level ?d ?l))))

  (:action shake
  	   :parameters (?b - cocktail ?d1 ?d2 - ingredient ?s - shaker ?h1 ?h2 - hand)
           :precondition (and (holding ?h1 ?s)
			      (unshaked ?s)
			      (contains ?s ?d1)
                              (contains ?s ?d2)
                              (cocktail-part1 ?b ?d1)
			      (cocktail-part2 ?b ?d2)
                              (handempty ?h2))
           :effect (and (shaked ?s)
                        (contains ?s ?b)
			(not (unshaked ?s))
		        (not (contains ?s ?d1))
                        (not (contains ?s ?d2))))

  (:action pour-shaker-to-shot
           :parameters (?b - beverage ?d - shot ?h - hand ?s - shaker ?l ?l1 - level)
           :precondition (and (holding ?h ?s)
			      (shaked ?s)
			      (contains ?s ?b)
			      (clean ?d)
			      (empty ?d)
                              (shaker-level ?s ?l)
                              (next ?l1 ?l))
           :effect (and (contains ?d ?b)
			(shaker-level ?s ?l1)
	   	   	(not (clean ?d))
	   	   	(not (empty ?d))
			(not (shaker-level ?s ?l))))

  (:action empty-shaker
           :parameters (?h - hand ?s - shaker ?b - cocktail ?l ?l1 - level)
           :precondition (and (holding ?h ?s)
			      (shaked ?s)
                              (contains ?s ?b)
			      (shaker-level ?s ?l)
			      (shaker-empty-level ?s ?l1))
           :effect (and (empty ?s)
			(shaker-level ?s ?l1)
	   	   	(not (shaked ?s))
	   	   	(not (shaker-level ?s ?l))
			(not (contains ?s ?b))))

  (:action clean-shaker
  	   :parameters (?h1 ?h2 - hand ?s - shaker)
           :precondition (and (holding ?h1 ?s)
                              (empty ?s)
                              (handempty ?h2))
           :effect (and (clean ?s)))
 )